{
  "name": "@pocketenv/sdk",
  "version": "0.2.4",
  "description": "Official JavaScript/TypeScript SDK for the Pocketenv API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run test"
  },
  "keywords": [
    "pocketenv",
    "sandbox",
    "sdk",
    "api",
    "cloud"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pocketenv-io/pocketenv-js.git"
  },
  "homepage": "https://pocketenv.io",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/tar": "^7.0.87",
    "typescript": "^5"
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "libsodium-wrappers": "^0.8.2",
    "tar": "^7.5.13",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18"
  }
}
